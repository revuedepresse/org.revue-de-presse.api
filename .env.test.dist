# Test-environment overrides on top of .env. CI copies this file to
# .env.test.local before running the suite; locally Symfony layers it via
# the standard .env / .env.local / .env.{env} / .env.{env}.local order.
# Only declare what differs from .env defaults.

APP_ENV=test
APP_DEBUG=false
APP_SECRET='36b770f153b113f7cb0d62979fbbe7d5e2bca6ff9944e3a9381642f690db0a17'

# In-memory sqlite — fast and isolated per test process.
DATABASE_URL="sqlite:///:memory:"

# Disable the rate limiter so request volume can't trip throttling in tests.
RATE_LIMIT_ENABLED=false

# Allow CORS preflights from local test runners.
ALLOWED_ORIGIN='*'

# Tolerate framework deprecations during tests.
SYMFONY_DEPRECATIONS_HELPER=999999

# WebTestCase / KernelTestCase entry point.
KERNEL_CLASS='App\Kernel'

# Test-only fixtures + scaffolding consumed by integration tests.
API_CLIENT_SECRET=''
DEVICE_MEMBER_ID='1'
BENCHMARK_HOST=''
DEBUG=
GITHUB_API_TOKEN=
LIST_DEFAULT=''
SERVICE='/var/www/api'
SERVICE_OWNER_UID=
SERVICE_OWNER_GID=

# TikTok OAuth — placeholder fixtures so the wired HttpTikTokOAuthClient
# passes its "configured?" guard in tests; the missing-credentials case
# overrides the wired client at the service level.
TIKTOK_CLIENT_KEY='test-key'
TIKTOK_CLIENT_SECRET='test-secret'

# Newsletter — test fixtures override the empty manifest values in .env.
# Encryption keys: base64 of 32 zero bytes (test-only, no real data).
NEWSLETTER_ENCRYPTION_KEY='AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA='
NEWSLETTER_ENCRYPTION_KEY_NEXT='AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA='
NEWSLETTER_BASE_URL=http://localhost
