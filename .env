###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=
###< symfony/framework-bundle ###

###> doctrine/doctrine-bundle ###
# Format described at https://www.doctrine-project.org/projects/doctrine-dbal/en/latest/reference/configuration.html#connecting-using-a-url
# For PostgreSQL: "postgresql://db_user:db_password@127.0.0.1:5432/db_name?serverVersion=14&charset=utf8"
# IMPORTANT: configure your server version, either here or in config/packages/doctrine.yaml
DATABASE_URL=
###< doctrine/doctrine-bundle ###

###> symfony/lock ###
# Choose one of the stores below
# postgresql+advisory://db_user:db_password@localhost/db_name
LOCK_DSN=flock
###< symfony/lock ###

###> symfony/mailer ###
# Dev: spin up Mailpit and point this at it.
#   docker run -d --name mailpit -p 1025:1025 -p 8025:8025 axllent/mailpit
# Prod: ses+smtps://AKIA…:secret@email-smtp.eu-west-1.amazonaws.com:587
MAILER_DSN=null://null
###< symfony/mailer ###

# CORS origin allowed by Nelmio Cors. Empty disables CORS; override in .env.local.
ALLOWED_ORIGIN=

# Rate limiter toggle — on by default; tests override to false.
RATE_LIMIT_ENABLED=true

# Reverse-proxy / host trust list consumed by public/index.php.
TRUSTED_PROXIES=
TRUSTED_HOSTS=

# Redis cache used by app + api-platform caches.
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# TikTok OAuth credentials. Used server-side by `POST /api/tiktok/oauth/exchange`
# to swap an authorization_code for access + refresh tokens. Both must be set
# for the exchange endpoint to function — empty values cause that endpoint to
# return 503; the callback endpoint stays functional regardless.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

###> newsletter ###
# Daily-report mailer settings — see src/Newsletter/README.md and the spec at
# internal-spec/specs/2026-05-23-org.revue-de-presse.api-newsletter-daily-report-design.md
NEWSLETTER_ACTING_USER=rdp-api
NEWSLETTER_DAILY_TZ=Europe/Paris
NEWSLETTER_CONFIRM_TTL_HOURS=168
NEWSLETTER_FROM_EMAIL=noreply@revue-de-presse.org
NEWSLETTER_FROM_NAME='Revue de Presse'
# Public origin where confirm + unsubscribe URLs resolve. Override per environment.
NEWSLETTER_BASE_URL=
NEWSLETTER_DESIGN_TOKENS_PATH=
# 32-byte XChaCha20-Poly1305 key for the encrypted email column.
# Generate with: openssl rand -base64 32
NEWSLETTER_ENCRYPTION_KEY=
# Optional. Set BEFORE running the rotation command to roll the key without
# downtime. The command re-encrypts every row with this NEXT value; you then
# swap NEW → primary and unset NEXT.
NEWSLETTER_ENCRYPTION_KEY_NEXT=
###< newsletter ###

