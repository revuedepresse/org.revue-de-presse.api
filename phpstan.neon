includes:
    - vendor/phpstan/phpstan-symfony/extension.neon
    - vendor/phpstan/phpstan-symfony/rules.neon
    - vendor/phpstan/phpstan-doctrine/extension.neon
    - vendor/phpstan/phpstan-doctrine/rules.neon
    - phpstan-baseline.neon

parameters:
    level: 5
    paths:
        - src
        - tests
        - public
    excludePaths:
        - src/Bluesky/Resources
        - tests/Resources
    ignoreErrors:
        # FrankenPHP worker-mode runtime functions — provided by the
        # FrankenPHP binary at request time, not by any composer package.
        # public/worker.php guards its first call with function_exists()
        # and throws RuntimeException when not running under FrankenPHP.
        -
            message: '#Function frankenphp_handle_request not found\.#'
            path: public/worker.php
    symfony:
        containerXmlPath: var/cache/test/App_KernelTestDebugContainer.xml
    doctrine:
        objectManagerLoader: tests/object-manager.php
