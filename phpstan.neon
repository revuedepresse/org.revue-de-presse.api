includes:
    - vendor/phpstan/phpstan-symfony/extension.neon
    - vendor/phpstan/phpstan-symfony/rules.neon
    - vendor/phpstan/phpstan-doctrine/extension.neon
    - vendor/phpstan/phpstan-doctrine/rules.neon
    - phpstan-baseline.neon

parameters:
    level: 5
    paths:
        - src
        - tests
        - public
    excludePaths:
        - src/Bluesky/Resources
        - tests/Resources
        # symfony/ai-* and firebase/php-jwt are listed in composer.json but
        # not installed in this slice. Drop the two excludes below once
        # `composer install` has resolved them, to bring these back under
        # static analysis.
        - src/Chat/Infrastructure/Symfony/Ai
        - src/Chat/Infrastructure/Security/BlueskyJwtAuthenticator.php
    symfony:
        containerXmlPath: var/cache/test/App_KernelTestDebugContainer.xml
    doctrine:
        objectManagerLoader: tests/object-manager.php
