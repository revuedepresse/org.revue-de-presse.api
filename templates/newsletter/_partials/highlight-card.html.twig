{# Receives: { rank, screen_name, avatar_url, text, date_fr, reposts, likes, url } #}
<table role="presentation" class="card" width="100%" cellpadding="0" cellspacing="0">
  <tr>
    {% if highlight.avatar_url %}
    <td valign="top" width="56" style="padding:16px 0 16px 16px">
      <a href="https://bsky.app/profile/{{ highlight.screen_name }}" style="display:inline-block;text-decoration:none">
        <img src="{{ highlight.avatar_url }}" width="40" height="40" alt="" style="border-radius:50%;display:block;border:0">
      </a>
    </td>
    {% endif %}
    <td valign="top" style="padding:16px">
      <div class="rank">{{ highlight.rank }}. <a href="https://bsky.app/profile/{{ highlight.screen_name }}" style="color:inherit;text-decoration:none">{{ highlight.screen_name }}</a></div>
      {% if highlight.text %}<div class="text">{{ highlight.text|nl2br }}</div>{% endif %}
      <div class="meta">
        <a href="{{ highlight.url }}" style="color:#657786;text-decoration:none">{{ highlight.date_fr }}</a>
        &nbsp;·&nbsp; <span class="vanity-retweets"><img src="data:image/png;base64," width="14" height="14" alt="" style="vertical-align:middle;border:0;margin-right:2px"> {{ highlight.reposts }}</span>
        &nbsp; <span class="vanity-likes"><img src="data:image/png;base64," width="14" height="14" alt="" style="vertical-align:middle;border:0;margin-right:2px"> {{ highlight.likes }}</span>
      </div>
      <div class="url"><a href="{{ highlight.url }}">{{ highlight.url }}</a></div>
    </td>
  </tr>
</table>
