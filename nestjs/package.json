{
  "name": "org.revue-de-presse.api-nest",
  "version": "6.0.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "lint": "eslint \"{src,test}/**/*.ts\" --max-warnings 0",
    "format": "prettier --check \"{src,test}/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "jest --config jest.config.ts",
    "test:unit": "jest --config jest.config.ts --testPathPattern test/unit",
    "test:component": "jest --config jest.config.ts --testPathPattern test/component",
    "test:e2e": "jest --config jest-e2e.config.ts",
    "test:perf": "jest --config jest-e2e.config.ts --testPathPattern test/perf",
    "db:introspect:check": "drizzle-kit introspect && node scripts/check-schema-drift.mjs"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/swagger": "^7.4.0",
    "better-sqlite3": "^12.0.0",
    "dotenv-flow": "^4.1.0",
    "drizzle-orm": "^0.36.0",
    "ioredis": "^5.4.0",
    "pg": "^8.13.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.2.0",
    "@nestjs/testing": "^10.4.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.7.0",
    "@types/pg": "^8.11.0",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^8.10.0",
    "@typescript-eslint/parser": "^8.10.0",
    "drizzle-kit": "^0.27.0",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.6.0"
  },
  "engines": { "node": ">=22.0.0" }
}
